{
  "app-id": "org.venturi.Venturi",
  "runtime": "org.gnome.Platform",
  "runtime-version": "48",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ],
  "command": "venturi",
  "finish-args": [
    "--share=network",
    "--socket=pulseaudio",
    "--filesystem=xdg-run/pipewire-0"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin"
  },
  "modules": [
    {
      "name": "venturi",
      "buildsystem": "simple",
      "build-commands": [
        "cargo build --release",
        "install -Dm755 target/release/venturi /app/bin/venturi",
        "install -Dm644 data/venturi.desktop /app/share/applications/org.venturi.Venturi.desktop",
        "install -Dm644 data/org.venturi.Venturi.svg /app/share/icons/hicolor/scalable/apps/org.venturi.Venturi.svg",
        "install -Dm644 data/org.venturi.Venturi.metainfo.xml /app/share/metainfo/org.venturi.Venturi.metainfo.xml"
      ],
      "sources": [
        {
          "type": "dir",
          "path": ".."
        }
      ]
    }
  ]
}
